@page
@model DigitalBanking.Dashboard.Pages.Reports.TopAccountsModel
@{
    ViewData["Title"] = "Top Accounts";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">Top Accounts</h3>
    <form method="get" class="d-flex gap-2">
        <input class="form-control" type="date" name="from" value="@Model.From" />
        <input class="form-control" type="date" name="to" value="@Model.To" />
        <input class="form-control" type="number" name="limit" value="@Model.Limit" min="1" max="100" style="width:120px;" />
        <button class="btn btn-outline-primary" type="submit">Apply</button>
    </form>
</div>

@if (!string.IsNullOrEmpty(Model.Error))
{
    <div class="alert alert-danger">@Model.Error</div>
}

@if (Model.Items?.Count > 0)
{
    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-striped table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>AccountId</th>
                        <th class="text-end">Tx Count</th>
                        <th class="text-end">Deposit Total</th>
                        <th class="text-end">Withdraw Total</th>
                        <th class="text-end">Net Flow</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var x in Model.Items)
                    {
                        <tr>
                            <td style="font-family:monospace;">@x.AccountId.ToString().Substring(0, 8)…</td>
                            <td class="text-end">@x.TransactionCount</td>
                            <td class="text-end">@x.DepositTotal.ToString("N2")</td>
                            <td class="text-end">@x.WithdrawTotal.ToString("N2")</td>
                            <td class="text-end">@x.NetFlow.ToString("N2")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
else
{
    <div class="alert alert-secondary">Veri yok.</div>
}